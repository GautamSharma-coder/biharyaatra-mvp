"use client";
import React, { useState, useEffect, Suspense, useMemo } from 'react';
import dynamic from 'next/dynamic';
import { useSearchParams, useRouter } from 'next/navigation';
import Link from 'next/link';
import MobileBottomNav from '@/components/MobileBottomNav';

function HomestayDetailContent() {
    const searchParams = useSearchParams();
    const router = useRouter();
    const id = searchParams.get('id');

    const [isScrolled, setIsScrolled] = useState(false);
    const [mobileMenu, setMobileMenu] = useState(false);
    const [servicesOpen, setServicesOpen] = useState(false);
    const [userMenu, setUserMenu] = useState(false);

    // Mock user state
    const [isLoggedIn, setIsLoggedIn] = useState(false);
    const [userName, setUserName] = useState('Traveler');
    const [userAvatar, setUserAvatar] = useState('https://ui-avatars.com/api/?name=Traveler&background=f97316&color=fff');

    const [loading, setLoading] = useState(true);
    const [item, setItem] = useState<any>(null);

    const [checkIn, setCheckIn] = useState('');
    const [checkOut, setCheckOut] = useState('');
    const [guests, setGuests] = useState('1');

    useEffect(() => {
        const handleScroll = () => {
            setIsScrolled(window.scrollY > 60);
        };
        window.addEventListener('scroll', handleScroll);

        // Mock fetch
        setTimeout(() => {
            if (id) {
                // Return generic data if ID matches but isn't specific
                setItem({
                    id: id,
                    name: 'Homestay ' + id,
                    location: 'Bihar',
                    price: 1500,
                    rating: 4.8,
                    reviews: 124,
                    hostName: 'Local Host',
                    badge: 'Superhost',
                    image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?q=80&w=1200',
                    description: 'A beautiful heritage home. Perfect for those seeking peace and a touch of history.',
                    amenities: ['wifi', 'kitchen', 'ac', 'river_view', 'parking']
                });
            } else {
                setItem({
                    id: 'demo-hs-1',
                    name: 'Ganga Kinare Haveli',
                    location: 'Patna, Bihar',
                    price: 1500,
                    rating: 4.8,
                    reviews: 124,
                    hostName: 'Ramesh Babu',
                    badge: 'Superhost',
                    image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?q=80&w=1200',
                    description: 'A beautiful heritage home overlooking the Ganges. Perfect for those seeking peace and a touch of history. We serve authentic Bihari Litti Chokha.',
                    amenities: ['wifi', 'kitchen', 'ac', 'river_view']
                });
            }
            setLoading(false);
        }, 800);

        return () => window.removeEventListener('scroll', handleScroll);
    }, [id]);

    const nightsCount = useMemo(() => {
        if (!checkIn || !checkOut) return 1;
        const start = new Date(checkIn);
        const end = new Date(checkOut);
        const diff = end.getTime() - start.getTime();
        const days = diff / (1000 * 60 * 60 * 24);
        return days > 0 ? days : 1;
    }, [checkIn, checkOut]);

    const getAmenityIcon = (amenity: string) => {
        const map: Record<string, string> = {
            'wifi': 'fas fa-wifi',
            'kitchen': 'fas fa-utensils',
            'ac': 'fas fa-snowflake',
            'parking': 'fas fa-car',
            'garden': 'fas fa-leaf',
            'river_view': 'fas fa-water'
        };
        return map[amenity.toLowerCase()] || 'fas fa-check';
    };

    const capitalize = (str: string) => {
        return str.charAt(0).toUpperCase() + str.slice(1).replace('_', ' ');
    };

    const proceedToBook = () => {
        if (!isLoggedIn) {
            alert('Please log in to book this homestay.');
            return;
        }
        if (!checkIn || !checkOut) {
            alert('Please select check-in and check-out dates.');
            return;
        }

        const total = (item.price * nightsCount) + 250;
        alert(`Proceeding to reserve ${item.name} for ${nightsCount} nights at ₹${total}`);
    };

    return (
        <div className="bg-[#FAFAFA] text-gray-900 font-sans overflow-x-hidden min-h-screen flex flex-col">
            <style dangerouslySetInnerHTML={{
                __html: `
                .gallery-grid {
                    display: grid;
                    grid-template-columns: 2fr 1fr;
                    grid-template-rows: 200px 200px;
                    gap: 1rem;
                }
                .gallery-main {
                    grid-row: 1 / 3;
                }
                @media (max-width: 768px) {
                    .gallery-grid {
                        grid-template-columns: 1fr;
                        grid-template-rows: 250px;
                    }
                    .gallery-sub {
                        display: none;
                    }
                }
            `}} />

            {/* Header */}
            <header className={`fixed w-full top-0 z-50 transition-all duration-300 ${isScrolled ? 'bg-white/90 backdrop-blur-lg shadow-md py-3' : 'bg-transparent py-5'}`}>
                <div className="max-w-7xl mx-auto px-6">
                    <div className="flex items-center justify-between">
                        <Link href="/" className="font-display font-bold text-2xl tracking-tighter flex items-center gap-2">
                            Bihar<span className="text-gradient hover:text-orange-500">Yaatra</span>
                        </Link>

                        <nav className="hidden md:flex items-center space-x-8">
                            <Link href="/explore-destination" className="nav-item font-medium">Destinations</Link>

                            <div className="relative" onMouseLeave={() => setServicesOpen(false)}>
                                <button onMouseEnter={() => setServicesOpen(true)} className="nav-item font-medium flex items-center gap-1.5 transition-colors duration-200">
                                    Services <i className={`fas fa-chevron-down text-xs ml-1 transition-transform ${servicesOpen ? 'rotate-180' : ''}`}></i>
                                </button>
                                {servicesOpen && (
                                    <div className="absolute left-1/2 -translate-x-1/2 mt-4 w-56 bg-white rounded-xl shadow-xl border border-gray-100 p-2 transform origin-top">
                                        <Link href="/packages" className="block px-4 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"><i className="fas fa-calendar-alt w-4 mr-2 text-blue-500"></i> Tour Packages</Link>
                                        <Link href="/aiplanner" className="block px-4 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"><i className="fas fa-compass w-4 mr-2 text-purple-500"></i> AI Trip Planner</Link>
                                        <Link href="/homestay" className="block px-4 py-2 text-orange-600 bg-orange-50 rounded-lg transition-colors"><i className="fas fa-heart w-4 mr-2 text-orange-500"></i> Homestays</Link>
                                        <Link href="/transport" className="block px-4 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"><i className="fas fa-bus-alt w-4 mr-2 text-green-500"></i> Transport</Link>
                                        <div className="border-t border-gray-100 my-1"></div>
                                        <Link href="/guide-support" className="block px-4 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"><i className="fas fa-user-tie w-4 mr-2 text-teal-500"></i> Expert Guides</Link>
                                    </div>
                                )}
                            </div>
                            <Link href="/about" className="nav-item font-medium">About</Link>
                            <Link href="/contact" className="nav-item font-medium">Contact</Link>

                            {!isLoggedIn ? (
                                <Link href="/auth" className="px-6 py-2.5 rounded-full bg-gradient-to-r from-orange-400 to-pink-500 text-white font-medium transition-all shadow-md hover:shadow-lg hover:scale-105 hover:-translate-y-0.5">
                                    Login
                                </Link>
                            ) : (
                                <div className="relative" onMouseLeave={() => setUserMenu(false)}>
                                    <button onMouseEnter={() => setUserMenu(true)} className="flex items-center gap-2 focus:outline-none">
                                        <img src={userAvatar} className="w-10 h-10 rounded-full border-2 border-orange-100 object-cover" alt="User Pic" />
                                        <i className={`fas fa-chevron-down text-xs text-gray-400 transition-transform ${userMenu ? 'rotate-180' : ''}`}></i>
                                    </button>
                                    {userMenu && (
                                        <div className="absolute right-0 mt-4 w-48 bg-white rounded-xl shadow-xl border border-gray-100 p-2 overflow-hidden">
                                            <a href="/dashboard" className="block px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 rounded-lg transition-colors">Dashboard</a>
                                            <div className="border-t border-gray-100 my-1"></div>
                                            <button onClick={() => setIsLoggedIn(false)} className="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors">Logout</button>
                                        </div>
                                    )}
                                </div>
                            )}
                        </nav>

                        <button onClick={() => setMobileMenu(!mobileMenu)} className="md:hidden focus:outline-none text-gray-800">
                            <i className="fas fa-bars text-2xl"></i>
                        </button>
                    </div>
                </div>
            </header>

            {/* Mobile Menu */}
            {mobileMenu && (
                <div className="fixed inset-0 z-50 flex justify-end">
                    <div className="absolute inset-0 bg-black/40 backdrop-blur-sm" onClick={() => setMobileMenu(false)}></div>
                    <div className="relative w-full max-w-xs bg-white shadow-2xl h-full flex flex-col pt-0 animate-slide-in-right">
                        <div className="px-6 py-6 flex items-center justify-between border-b border-gray-100">
                            <span className="font-display font-bold text-xl">Menu</span>
                            <button onClick={() => setMobileMenu(false)} className="text-gray-500 hover:text-red-500 transition">
                                <i className="fas fa-times text-xl"></i>
                            </button>
                        </div>
                        <div className="flex-1 px-6 py-6 overflow-y-auto space-y-4">
                            <Link href="/explore-destination" className="block text-lg font-medium hover:text-orange-600 transition">Destinations</Link>
                            <Link href="/packages" className="block text-lg font-medium hover:text-orange-600 transition">Packages</Link>
                            <Link href="/homestay" className="block text-lg font-medium hover:text-orange-600 transition">Homestays</Link>
                            <Link href="/transport" className="block text-lg font-medium hover:text-orange-600 transition">Transports</Link>
                            <Link href="/guide-support" className="block text-lg font-medium hover:text-orange-600 transition">Guides</Link>
                        </div>
                    </div>
                </div>
            )}

            <main className="flex-1 pt-32 pb-20">
                {loading ? (
                    <div className="flex flex-col items-center justify-center py-40 text-gray-400">
                        <i className="fas fa-circle-notch fa-spin text-4xl text-orange-500 mb-4"></i>
                        <p className="font-bold">Loading home details...</p>
                    </div>
                ) : (
                    item && (
                        <div className="max-w-7xl mx-auto px-6">
                            <div className="mb-8">
                                <h1 className="font-display text-4xl md:text-5xl font-bold mb-2 text-gray-900">{item.name}</h1>
                                <div className="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                                    <span className="flex items-center gap-1">
                                        <i className="fas fa-star text-orange-500"></i>
                                        <strong className="text-black">{item.rating}</strong>
                                        <span>({item.reviews} reviews)</span>
                                    </span>
                                    <span>•</span>
                                    <span className="flex items-center gap-1">
                                        <i className="fas fa-map-marker-alt text-gray-400"></i>
                                        <span>{item.location}</span>
                                    </span>
                                    <span>•</span>
                                    <span className="text-orange-600 font-bold">{item.badge}</span>
                                </div>
                            </div>

                            <div className="gallery-grid mb-12 rounded-[2rem] overflow-hidden shadow-lg">
                                <img src={item.image} className="gallery-main w-full h-full object-cover hover:scale-105 transition duration-700 cursor-pointer" alt="Main" />
                                <img src="https://images.unsplash.com/photo-1598928506311-c55ded91a20c?q=80&w=800" className="gallery-sub w-full h-full object-cover hover:scale-105 transition duration-700 cursor-pointer" alt="Sub 1" />
                                <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=80&w=800" className="gallery-sub w-full h-full object-cover hover:scale-105 transition duration-700 cursor-pointer" alt="Sub 2" />
                            </div>

                            <div className="grid grid-cols-1 lg:grid-cols-3 gap-12">
                                <div className="lg:col-span-2 space-y-10">
                                    <div className="flex items-center justify-between py-6 border-b border-gray-100">
                                        <div>
                                            <h3 className="font-display font-bold text-2xl">Hosted by <span>{item.hostName || 'Local Family'}</span></h3>
                                            <p className="text-gray-500 text-sm">Superhost • 5 Years hosting</p>
                                        </div>
                                        <div className="w-14 h-14 rounded-full bg-gray-200 overflow-hidden border-2 border-white shadow-md">
                                            <img src={`https://ui-avatars.com/api/?name=${item.hostName || 'Host'}&background=random`} className="w-full h-full object-cover" alt="Host" />
                                        </div>
                                    </div>

                                    <div>
                                        <h3 className="font-bold text-xl mb-4 font-display">About this home</h3>
                                        <p className="text-gray-600 leading-relaxed text-lg">{item.description}</p>
                                    </div>

                                    <div>
                                        <h3 className="font-bold text-xl mb-6 font-display">What this place offers</h3>
                                        <div className="grid grid-cols-2 gap-4">
                                            {item.amenities?.map((amenity: string) => (
                                                <div key={amenity} className="flex items-center gap-3 text-gray-700">
                                                    <i className={`${getAmenityIcon(amenity)} text-gray-400 w-6 text-xl`}></i>
                                                    <span className="font-medium text-lg">{capitalize(amenity)}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>

                                    <div className="rounded-3xl overflow-hidden h-64 bg-gray-100 relative group">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/e/e4/Map_of_Bihar.jpg" className="w-full h-full object-cover opacity-50" alt="Map" />
                                        <div className="absolute inset-0 flex items-center justify-center">
                                            <button className="bg-white px-6 py-3 rounded-full font-bold shadow-lg hover:scale-105 transition text-orange-600">
                                                <i className="fas fa-map-marked-alt mr-2"></i> Show on Map
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div className="lg:col-span-1">
                                    <div className="bg-white border border-gray-100 shadow-xl rounded-[2rem] p-8 sticky top-28">
                                        <div className="flex justify-between items-end mb-6">
                                            <div>
                                                {item.originalPrice && (
                                                    <p className="text-xs text-gray-400 font-bold uppercase line-through">₹<span>{item.originalPrice}</span></p>
                                                )}
                                                <h3 className="text-3xl font-bold font-display text-gray-900">₹<span>{item.price}</span> <span className="text-base font-normal text-gray-500">/ night</span></h3>
                                            </div>
                                            <div className="flex items-center gap-1 text-sm font-bold">
                                                <i className="fas fa-star text-orange-500"></i>
                                                <span>{item.rating}</span>
                                            </div>
                                        </div>

                                        <div className="border rounded-xl overflow-hidden mb-4">
                                            <div className="grid grid-cols-2 border-b">
                                                <div className="p-3 border-r">
                                                    <label className="block text-[10px] font-bold uppercase text-gray-500">Check-In</label>
                                                    <input type="date" value={checkIn} onChange={(e) => setCheckIn(e.target.value)} className="w-full outline-none text-sm font-bold bg-transparent cursor-pointer" />
                                                </div>
                                                <div className="p-3">
                                                    <label className="block text-[10px] font-bold uppercase text-gray-500">Check-Out</label>
                                                    <input type="date" value={checkOut} onChange={(e) => setCheckOut(e.target.value)} className="w-full outline-none text-sm font-bold bg-transparent cursor-pointer" />
                                                </div>
                                            </div>
                                            <div className="p-3 border-t">
                                                <label className="block text-[10px] font-bold uppercase text-gray-500">Guests</label>
                                                <select value={guests} onChange={(e) => setGuests(e.target.value)} className="w-full outline-none text-sm font-bold bg-transparent cursor-pointer">
                                                    <option value="1">1 Guest</option>
                                                    <option value="2">2 Guests</option>
                                                    <option value="3">3 Guests</option>
                                                </select>
                                            </div>
                                        </div>

                                        <button onClick={proceedToBook} className="w-full py-4 bg-gradient-to-r from-orange-400 to-pink-500 text-white font-bold rounded-xl shadow-lg hover:opacity-90 transition-all duration-300 mb-4 flex justify-center items-center gap-2">
                                            <span>Reserve</span>
                                            <i className="fas fa-bolt"></i>
                                        </button>

                                        {checkIn && checkOut && (
                                            <div className="space-y-3 text-sm text-gray-600">
                                                <div className="flex justify-between">
                                                    <span>₹{item.price} x {nightsCount} nights</span>
                                                    <span>₹{item.price * nightsCount}</span>
                                                </div>
                                                <div className="flex justify-between">
                                                    <span>Service Fee</span>
                                                    <span>₹250</span>
                                                </div>
                                                <hr />
                                                <div className="flex justify-between font-bold text-lg text-gray-900">
                                                    <span>Total</span>
                                                    <span>₹{(item.price * nightsCount) + 250}</span>
                                                </div>
                                            </div>
                                        )}

                                        <p className="text-xs text-center text-gray-400 mt-4">You won't be charged yet</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    )
                )}
            </main>

            <MobileBottomNav />
        </div>
    );
}

const ViewHomestayDetailPage = dynamic(() => Promise.resolve(HomestayDetailContent), { 
    ssr: false,
    loading: () => <div className="min-h-screen flex items-center justify-center"><i className="fas fa-circle-notch fa-spin text-4xl text-orange-500"></i></div>
});
export default ViewHomestayDetailPage;
